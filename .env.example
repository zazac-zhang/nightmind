# ============================================================
# NightMind 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值

# ============================================================
# 数据库配置
# ============================================================
DATABASE_URL=postgresql://nightmind:nightmind_password@localhost:5432/nightmind
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5

# ============================================================
# Redis 配置
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# ============================================================
# Qdrant 配置
# ============================================================
QDRANT_URL=http://localhost:6334
QDRANT_COLLECTION_NAME=knowledge_points
QDRANT_VECTOR_SIZE=1536

# ============================================================
# OpenAI API
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ============================================================
# Anthropic Claude (备选)
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================================
# STT/TTS 服务
# ============================================================

# Whisper (OpenAI)
WHISPER_API_KEY=sk-your-openai-api-key-here
WHISPER_MODEL=whisper-1

# ElevenLabs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE=Rachel
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_SPEED=1.0

# Azure TTS (备选)
AZURE_TTS_API_KEY=your-azure-tts-key-here
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ============================================================
# Anki 集成
# ============================================================
ANKI_CONNECT_URL=http://localhost:8765
ANKI_DEFAULT_DECK=NightMind
ANKI_SYNC_ON_SESSION_END=true

# ============================================================
# Obsidian 集成
# ============================================================
OBSIDIAN_VAULT_PATH=/Users/yourname/Obsidian
OBSIDIAN_DAILY_NOTE_TEMPLATE=NightMind
OBSIDIAN_AUTO_SYNC=true
OBSIDIAN_WATCH_FOLDERS=Knowledge,Inbox

# ============================================================
# Notion 集成
# ============================================================
NOTION_API_KEY=your-notion-integration-token-here
NOTION_KNOWLEDGE_BASE_ID=your-database-id-here
NOTION_SESSION_LOG_ID=your-session-log-id-here

# ============================================================
# Readwise 集成
# ============================================================
READWISE_API_KEY=your-readwise-access-token-here

# ============================================================
# 服务配置
# ============================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# ============================================================
# JWT 配置
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# ============================================================
# 日志配置
# ============================================================
RUST_LOG=info,nightmind=debug
RUST_BACKTRACE=1
LOG_FORMAT=json

# ============================================================
# 会话配置
# ============================================================
SESSION_DEFAULT_DURATION=3600
SESSION_MAX_DURATION=7200
SESSION_AUTO_CLOSE_TIMEOUT=3600
SESSION_SNAPSHOT_INTERVAL=30

# ============================================================
# WebSocket 配置
# ============================================================
WS_MESSAGE_SIZE_LIMIT=10485760
WS_HEARTBEAT_INTERVAL=30

# ============================================================
# 速率限制
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============================================================
# 开发模式
# ============================================================
DEV_MODE=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# ============================================================
# 特性开关
# ============================================================
FEATURE_ANKI_INTEGRATION=true
FEATURE_OBSIDIAN_INTEGRATION=true
FEATURE_NOTION_INTEGRATION=false
FEATURE_READWISE_INTEGRATION=false
FEATURE_LOCAL_LLM=false
FEATURE_ANALYTICS=false
